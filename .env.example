# ============================================================
# MédiHelm — Variables d'environnement
# Copiez ce fichier en .env et remplissez les valeurs
# ============================================================

# === Base de données ===
# SQLite pour le développement local
DATABASE_URL="file:./dev.db"
# PostgreSQL (Neon) pour la production
# DATABASE_URL="postgresql://user:password@host:5432/medihelm?sslmode=require"

# === NextAuth.js v4 ===
# URL de base de l'application
NEXTAUTH_URL="http://localhost:3000"
# Secret pour signer les JWT (générer avec: openssl rand -base64 32)
NEXTAUTH_SECRET="change-me-to-a-secure-random-string-in-production"

# === DPMED (Direction de la Pharmacie et du Médicament) ===
# Secret partagé pour valider les signatures HMAC des webhooks DPMED
DPMED_WEBHOOK_SECRET="dpmed-webhook-secret-change-me"
# Clé publique DPMED pour la vérification des signatures numériques
DPMED_PUBLIC_KEY="dpmed-public-key-placeholder"

# === SoBAPS (Société Béninoise d'Approvisionnement Pharmaceutique) ===
# Secret partagé pour valider les signatures HMAC des webhooks SoBAPS
SOBAPS_WEBHOOK_SECRET="sobaps-webhook-secret-change-me"

# === UbiPharm ===
# URL de l'API UbiPharm
UBIPHARM_API_URL="https://api.ubipharm.example.com"
# Clé API pour authentifier les requêtes sortantes vers UbiPharm
UBIPHARM_API_KEY="ubipharm-api-key-change-me"
# Secret partagé pour valider les signatures HMAC des webhooks UbiPharm
UBIPHARM_WEBHOOK_SECRET="ubipharm-webhook-secret-change-me"

# === Promopharma ===
# URL de l'API Promopharma
PROMOPHARMA_API_URL="https://api.promopharma.example.com"
# Clé API pour authentifier les requêtes sortantes vers Promopharma
PROMOPHARMA_API_KEY="promopharma-api-key-change-me"
# Secret partagé pour valider les signatures HMAC des webhooks Promopharma
PROMOPHARMA_WEBHOOK_SECRET="promopharma-webhook-secret-change-me"
